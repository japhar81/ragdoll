# Map the client's `Upgrade` header to the upstream `Connection` value so
# WebSocket upgrades for `/api/events` are forwarded rather than swallowed.
# Regular HTTP requests (where `$http_upgrade` is empty) send `Connection: ""`
# which nginx treats as "no Connection header" — i.e. the old behaviour.
map $http_upgrade $connection_upgrade {
    default upgrade;
    ''      '';
}

server {
    # Listen on 8080, NOT 80: this image is nginxinc/nginx-unprivileged
    # (UID 101, no CAP_NET_BIND_SERVICE — can't bind ports < 1024), the
    # same image OpenShift restricted-v2 SCC requires. The Dockerfile
    # EXPOSEs 8080 and docker-compose publishes 8088:8080. All three
    # (Dockerfile / this file / compose) must agree on 8080. (issues #1)
    listen 8080;
    server_name _;
    root /usr/share/nginx/html;
    index index.html;

    # Per-request DNS re-resolution of `api` (issues #4): the variable
    # proxy_pass below needs an nginx `resolver`, and nginx's resolver does
    # NOT read /etc/resolv.conf — it queries the literal address given.
    # `${NGINX_LOCAL_RESOLVERS}` is substituted at container start from the
    # container's OWN /etc/resolv.conf nameserver(s) by the nginx image's
    # built-in 15-local-resolvers.envsh entrypoint step (enabled via
    # NGINX_ENTRYPOINT_LOCAL_RESOLVERS=1 in web.Dockerfile), so this works on
    # Docker (127.0.0.11), Podman (the network DNS, e.g. 10.89.x.1), and any
    # other runtime — instead of hard-coding Docker's embedded-DNS address,
    # which 502'd everywhere else (issues #12). This is why nginx.conf ships
    # as an `*.template`: the entrypoint's envsubst fills the var in.
    # `valid=10s` re-resolves periodically so a `make refresh` that recreates
    # the api container (NEW IP) is picked up without a `web` restart.
    # Compose-only: the k8s/helm path uses a templated ConfigMap whose `api`
    # is a stable Service ClusterIP, so it needs no resolver.
    resolver ${NGINX_LOCAL_RESOLVERS} valid=10s ipv6=off;
    set $api_upstream http://api:3001;

    # Reverse-proxy control-plane endpoints to the api service so the SPA can
    # call relative /api, /healthz, /readyz paths with no CORS. The
    # Upgrade/Connection pair is required for the `/api/events` WebSocket.
    location /api/ {
        # Variable in proxy_pass → nginx defers DNS resolution to
        # request time (re-resolving via the resolver above). No URI
        # part on the variable → the original request URI is forwarded
        # unchanged, matching the old static `proxy_pass http://api:3001;`.
        proxy_pass $api_upstream;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
        # RAG runs on CPU Ollama can be slow on first call.
        proxy_read_timeout 600s;
        proxy_buffering off;
    }

    location = /healthz {
        proxy_pass $api_upstream/healthz;
        proxy_set_header Host $host;
    }

    location = /readyz {
        proxy_pass $api_upstream/readyz;
        proxy_set_header Host $host;
    }

    # SPA fallback: any unknown path serves index.html.
    location / {
        try_files $uri $uri/ /index.html;
    }
}
