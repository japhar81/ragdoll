{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["vite/client"],
    "moduleResolution": "Bundler",
    "module": "ESNext",
    "allowImportingTsExtensions": true,
    "noEmit": true
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "test/**/*.ts", "vite.config.ts"],
  // Override the root tsconfig's `exclude` (which lists `apps/web` so the
  // root project doesn't try to compile this workspace with its NodeNext
  // module + no-JSX settings). Without this override, the web project
  // inherits the parent exclude and ends up excluding ITSELF — every
  // file in apps/web is both included by this project and excluded by
  // the inherited list, which the TypeScript LSP refuses to load.
  "exclude": ["node_modules"]
}
